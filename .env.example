# =============================================================================
# IncidentIQ environment file
#
# Copy this file to .env, fill in your Gemini key, then run:
#   docker compose up -d --build
#
# .env is gitignored. NEVER commit your real key.
# =============================================================================

# Required for AI features (auto-categorize, similar incidents, resolution
# suggestion, thread summary). Leave empty to run without AI — the app still
# works, AI features just return graceful errors.
#
# Get a key (free tier) at https://aistudio.google.com/app/apikey
APP_GEMINI_API_KEY=

# Optional: override defaults
APP_GEMINI_MODEL=gemini-2.5-flash
APP_GEMINI_TEMPERATURE=0.3

# MySQL root password (used both inside the container and by the app to connect)
MYSQL_ROOT_PASSWORD=rootpw

# Branding shown in PDF reports + UI footer
APP_SYSTEM_NAME=IncidentIQ
APP_ORGANIZATION_NAME=Demo Org
